  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u043E\u0431\u0440\u0430\u0437\u0435\u0446
    \u044E\u0432\u0435\u043B\u0438\u0440\u043D\u043E\u0433\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    \u044D\u043F\u043E\u0445\u0438 \u0431\u0430\u0440\u043E\u043A\u043A\u043E \u2014
    \u043F\u0430\u0440\u0430\u0434\u043D\u044B\u0439 \u043A\u0443\u0431\u043E\u043A,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0430\u0432\u0448\u0438\u0439\u0441\u044F
    \u0434\u043B\u044F \u0442\u043E\u0440\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u0439 \u0438 \u043F\u0438\u0440\u043E\u0432
    \u0432\u044B\u0441\u0448\u0435\u0439 \u0437\u043D\u0430\u0442\u0438. \u0421\u043E\u0441\u0443\u0434
    \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D \u0438\u0437 \u0432\u044B\u0441\u043E\u043A\u043E\u043F\u0440\u043E\u0431\u043D\u043E\u0433\u043E
    \u0441\u0435\u0440\u0435\u0431\u0440\u0430 \u0441 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C \u0437\u043E\u043B\u043E\u0447\u0435\u043D\u0438\u0435\u043C,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u0435\u0442 \u043C\u0435\u0442\u0430\u043B\u043B\u0443
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u044B\u0439 \u043C\u044F\u0433\u043A\u0438\u0439
    \xAB\u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439\xBB \u0431\u043B\u0435\u0441\u043A,
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F."
  m_isRightToLeft: 0
